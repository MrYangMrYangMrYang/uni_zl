# ============================================
# 知了论坛 - 环境变量配置模板
# 复制为 .env.development.local 启动开发环境
# ============================================

# H5 端 API 路径（开发时通过 vue.config.js 代理，无需修改）
VUE_APP_API_H5=/wc

# 小程序 / APP 端 API 完整地址
VUE_APP_API_NATIVE=http://localhost/index.php/wc

# 静态资源域名（用于图片路径处理）
VUE_APP_DOMAIN=http://localhost
