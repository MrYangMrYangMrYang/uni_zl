# ============================================
# 生产环境配置 — 部署前务必修改以下三项
# ============================================

# H5 端 API 路径（配合 Nginx 反向代理，通常无需修改）
VUE_APP_API_H5=/wc

# 小程序 / APP 端 API 完整地址 ← 替换为你的后端地址
VUE_APP_API_NATIVE=http://www.fastadmin.com/index.php/wc

# 静态资源域名（用于 H5 端剥离图片绝对路径中的域名，使其走 Nginx 代理）
# 必须与后端返回的图片 URL 域名完全一致！
VUE_APP_DOMAIN=http://www.fastadmin.com
