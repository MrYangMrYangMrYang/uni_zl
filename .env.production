# ============================================
# 生产环境配置 — 部署前务必修改以下三项
# ============================================

# H5 端 API 路径（通常配合 Nginx 反向代理，无需修改）
VUE_APP_API_H5=/wc

# 小程序 / APP 端 API 完整地址 ← 替换为你的后端地址
VUE_APP_API_NATIVE=https://替换为实际后端域名/index.php/wc

# 静态资源域名 ← 替换为你的域名
VUE_APP_DOMAIN=https://替换为实际域名
